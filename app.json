{
  "expo": {
    "name": "NEWSWORLD",
    "slug": "NEWSWORLD",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo-light.png",
    "scheme": "newsworld",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "GRJVX377AP",
      "entitlements": {
        "com.apple.developer.networking.wifi-info": true
      },
      "bundleIdentifier": "com.joshcodes.newslite",
      "version": "1.1.1",
      "buildNumber": "6",
      "associatedDomains": [
        "applinks:api.newsworldapp.org"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "androidStatusBar": {
      "translucent": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/smallLogoA.png",
        "backgroundColor": "#F9FAFB"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.joshcodes.newslite",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.newsworldapp.org",
              "pathPrefix": "/article"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "@bacons/apple-targets",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F9FAFB",
          "dark": {
            "image": "./assets/images/logo-dark.png",
            "backgroundColor": "#1A1D21"
          }
        }
      ],
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NEWSWORLD to access your photos.",
          "cameraPermission": "Allow NEWSWORLD to access your camera."
        }
      ],
      [
        "react-native-share",
        {
          "ios": [
            "fb",
            "instagram",
            "twitter",
            "tiktoksharesdk",
            "whatsapp",
            "whatsappbusiness"
          ],
          "android": [
            "com.facebook.katana",
            "com.instagram.android",
            "com.twitter.android",
            "com.zhiliaoapp.musically",
            "com.whatsapp",
            "com.whatsapp.w4b"
          ],
          "enableBase64ShareAndroid": true
        }
      ],
      "expo-audio",
      "expo-build-properties",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/CabinetGrotesk-Black.otf",
            "./assets/fonts/CabinetGrotesk-Bold.otf",
            "./assets/fonts/CabinetGrotesk-Extrabold.otf",
            "./assets/fonts/CabinetGrotesk-Extralight.otf",
            "./assets/fonts/CabinetGrotesk-Light.otf",
            "./assets/fonts/CabinetGrotesk-Medium.otf",
            "./assets/fonts/CabinetGrotesk-Regular.otf",
            "./assets/fonts/CabinetGrotesk-Thin.otf",
            "./assets/fonts/CabinetGrotesk-Variable.ttf",
            "./assets/fonts/Montserrat-Black.otf",
            "./assets/fonts/Montserrat-BlackItalic.otf",
            "./assets/fonts/Montserrat-Bold.otf",
            "./assets/fonts/Montserrat-BoldItalic.otf",
            "./assets/fonts/Montserrat-ExtraBold.otf",
            "./assets/fonts/Montserrat-ExtraBoldItalic.otf",
            "./assets/fonts/Montserrat-ExtraLight.otf",
            "./assets/fonts/Montserrat-ExtraLightItalic.otf",
            "./assets/fonts/Montserrat-Italic.otf",
            "./assets/fonts/Montserrat-Light.otf",
            "./assets/fonts/Montserrat-LightItalic.otf",
            "./assets/fonts/Montserrat-Medium.otf",
            "./assets/fonts/Montserrat-MediumItalic.otf",
            "./assets/fonts/Montserrat-Regular.otf",
            "./assets/fonts/Montserrat-SemiBold.otf",
            "./assets/fonts/Montserrat-SemiBoldItalic.otf",
            "./assets/fonts/Montserrat-Thin.otf",
            "./assets/fonts/Montserrat-ThinItalic.otf",
            "./assets/fonts/Montserrat-Variable.ttf",
            "./assets/fonts/Montserrat-VariableItalic.ttf",
            "./assets/fonts/Manrope-Bold.otf",
            "./assets/fonts/Manrope-ExtraBold.otf",
            "./assets/fonts/Manrope-Extralight.otf",
            "./assets/fonts/Manrope-Light.otf",
            "./assets/fonts/Manrope-Medium.otf",
            "./assets/fonts/Manrope-Regular.otf",
            "./assets/fonts/Manrope-SemiBold.otf"
          ]
        }
      ],
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb64255b-76e8-4988-a31a-29a6eed2cd98"
      }
    }
  }
}
